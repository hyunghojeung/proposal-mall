# ── Supabase ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (Prisma) ────────────────────
# Supabase pooled connection (port 6543) for serverless
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ── 이메일 (네이버 SMTP) ───────────────────
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=blackcopy2@naver.com

# ── 사이다페이 (결제) ───────────────────
# CIDAPAY_API_BASE 가 비어 있으면 stub 어댑터(즉시 성공)로 동작 — 로컬 dev 검증용.
# 실제 운영에서는 가맹점 API base URL 을 채우면 cidapay 어댑터가 활성화됨.
CIDAPAY_API_BASE=
CIDAPAY_MID=
CIDAPAY_API_KEY=

# ── Dropbox (파일 전달) ─────────────────
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# ── 관리자 인증 ──────────────────────────
ADMIN_PASSWORD_HASH=     # bcrypt hash
ADMIN_SESSION_SECRET=    # 32+ char random string

# ── 서비스 ───────────────────────────────
NEXT_PUBLIC_SITE_URL=https://proposal.blackcopy.co.kr
